@model E_Commerce.View_Model.ForgotPasswordVM
@{
    Layout = "_AuthLayout";
}

<div class="container mt-5 text-center w-50">
    <h1>Recover Password</h1>

    <div class="row mt-4">
        
        <!-- LEFT SIDE -->
        <div class="">
            <h4>Forget Password to log in.</h4>
            <hr />

            @if (ViewBag.Message != null)
            {
                <div class="text-danger text-break">@ViewBag.Message</div>
            }
            <form method="post" >
                <div class="form-group mb-3">
    <input asp-for="Email" class="form-control" />
    </div>
                <div class="form-group mb-3">
                    <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
    </div>
</form>
</div></div></div>