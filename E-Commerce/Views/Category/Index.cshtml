@using E_Commerce.View_Model
@model List<CategoryVM>
<link href="~/css/category.css" rel="stylesheet" />
<script src="~/js/category.js"></script>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="page-title">Category List</h2>
        <a asp-action="Create" class="btn btn-primary btn-custom">+ Add Category</a>
    </div>

    <input type="text" id="searchInput" class="form-control mb-3" placeholder="Search category..." />

    <div class="card card-custom p-3">
        <table class="table table-hover" id="categoryTable">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Category Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>