@using E_Commerce.View_Model
@model CategoryVM
<link href="~/css/category.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card card-custom p-4 col-md-6 mx-auto">
        <h3 class="mb-3 text-center">Create Category</h3>

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Enter category name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary btn-custom">Back</a>
                <button type="submit" class="btn btn-success btn-custom">Save</button>
            </div>
        </form>
    </div>
</div>